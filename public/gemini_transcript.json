		{
			"timestamps": {
				"from": "00:02:43,000",
				"to": "00:02:43,000"
			},
			"offsets": {
				"from": 163000,
				"to": 163000
			},
			"text": " constant."
		},
		{
			"timestamps": {
				"from": "00:02:43,000",
				"to": "00:02:46,000"
			},
			"offsets": {
				"from": 163000,
				"to": 166000
			},
			"text": " And that's really the shift-worth understanding here."
		},
		{
			"timestamps": {
				"from": "00:02:46,000",
				"to": "00:02:51,280"
			},
			"offsets": {
				"from": 166000,
				"to": 171280
			},
			"text": " For a long time, we treated smartest model and best model as basically the same"
		},
		{
			"timestamps": {
				"from": "00:02:51,280",
				"to": "00:02:52,000"
			},
			"offsets": {
				"from": 171280,
				"to": 172000
			},
			"text": " thing."
		},
		{
			"timestamps": {
				"from": "00:02:52,000",
				"to": "00:02:56,220"
			},
			"offsets": {
				"from": 172000,
				"to": 176220
			},
			"text": " But usage data is quietly telling a different story that intelligence and"
		},
		{
			"timestamps": {
				"from": "00:02:56,220",
				"to": "00:02:58,000"
			},
			"offsets": {
				"from": 176220,
				"to": 178000
			},
			"text": " adoption are decoupling."
