		{
			"timestamps": {
				"from": "00:03:29,000",
				"to": "00:03:33,000"
			},
			"offsets": {
				"from": 209000,
				"to": 213000
			},
			"text": " What do you think that says about where this industry is actually headed?"
		},
		{
			"timestamps": {
				"from": "00:03:33,000",
				"to": "00:03:35,280"
			},
			"offsets": {
				"from": 213000,
				"to": 215280
			},
			"text": " this industry is actually headed."
		},
		{
			"timestamps": {
				"from": "00:03:35,280",
				"to": "00:03:37,040"
			},
			"offsets": {
				"from": 215280,
