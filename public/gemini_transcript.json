		},
		{
			"timestamps": {
				"from": "00:00:49,000",
				"to": "00:00:54,000"
			},
			"offsets": {
				"from": 49000,
				"to": 54000
			},
			"text": " The other measures usage, how many actual tokens people are running through it"
		},
		{
			"timestamps": {
